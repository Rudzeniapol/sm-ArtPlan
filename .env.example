# Copy this file to `.env` and fill in the values. `.env` is gitignored.

# --- Telegram (required) -----------------------------------------
# Talk to @BotFather on Telegram and run /newbot to get a token.
BOT_TOKEN=

# IANA tz id used as the default for newly registered users.
BOT_DEFAULT_TIMEZONE=Etc/UTC

# --- LLM (required, OpenAI-compatible) ---------------------------
# Works with any OpenAI-compatible chat-completions endpoint:
#   OpenAI:   https://api.openai.com/v1/   + key from platform.openai.com
#   DeepSeek: https://api.deepseek.com/v1/ + key from platform.deepseek.com
#   Groq:     https://api.groq.com/openai/v1/
LLM_BASE_URL=https://api.openai.com/v1/
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=30

# --- Postgres ----------------------------------------------------
POSTGRES_DB=goalsbot
POSTGRES_USER=goalsbot
POSTGRES_PASSWORD=changeme
# Host port to publish — only needed if you want to connect from your machine.
POSTGRES_PORT=5432

# --- Google Calendar (optional) ----------------------------------
# Drop your service-account JSON at ./secrets/google-credentials.json
# (mounted read-only into the container). Leave the rest as default.
# If unset, /sync simply replies that calendar isn't configured —
# the rest of the bot still works.
GOOGLE_CALENDAR_ID=primary
